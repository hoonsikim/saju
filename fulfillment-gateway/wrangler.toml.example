name = "saju-fulfillment-gateway"
main = "src/index.js"
compatibility_date = "2024-12-01"
workers_dev = true

[vars]
RESEND_FROM = "Saju Deep <readings@saju.thehueviz.com>"
EXPECTED_GUMROAD_SELLER_ID = "SET_AFTER_AUTHENTICATED_CANARY"
EXPECTED_GUMROAD_PRODUCT_ID = "SET_AFTER_AUTHENTICATED_CANARY"

# Secrets:
#   GUMROAD_ACCESS_TOKEN
#   FULFILLMENT_READING_TOKEN
#   RESEND_API_KEY
#   ADMIN_TOKEN
#   PING_TOKEN

[[services]]
binding = "SAJU_READING_WORKER"
service = "saju-reading"

[[d1_databases]]
binding = "DB"
database_name = "saju-fulfillment-orders"
database_id = "00000000-0000-0000-0000-000000000000"

[[queues.producers]]
binding = "FULFILLMENT_QUEUE"
queue = "saju-fulfillment"

[[queues.consumers]]
queue = "saju-fulfillment"
max_batch_size = 5
max_retries = 3
dead_letter_queue = "saju-fulfillment-dlq"
